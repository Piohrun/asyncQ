        "getOption": "const frame = context.panel.data.series[0];\nif (!frame) {\n  return {};\n}\n\nconst values = (field) => Array.from(field?.values || []);\nconst time = values(frame.fields.find((field) => field.name === 'time'));\nconst price = values(frame.fields.find((field) => field.name === 'price'));\nconst points = price.map((value, index) => [time[index], Number(value)]);\n\nreturn {\n  backgroundColor: 'transparent',\n  tooltip: { trigger: 'axis' },\n  grid: { left: 48, right: 24, top: 24, bottom: 36 },\n  xAxis: { type: 'time' },\n  yAxis: { type: 'value', scale: true },\n  series: [{ name: 'price', type: 'line', showSymbol: false, data: points }]\n};",
